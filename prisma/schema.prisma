// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ANCHOR NEURAL-NODE-ENTITY
model User {
  id             String    @id @default(uuid()) // Sovereign ID (UUID v4)
  email          String    @unique
  passwordHash   String    
  isVerified     Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  onboardingStep Int      @default(0)
}