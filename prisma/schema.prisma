// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ANCHOR NEURAL-NODE-ENTITY
model User {
  id             String    @id @default(uuid()) // Sovereign ID (UUID v4)
  email          String    @unique
  passwordHash   String?   // MUST BE OPTIONAL (?) FOR OAUTH USERS
  isVerified     Boolean   @default(false)
  onboardingStep Int       @default(0)
  oauthProvider  String?   // e.g., "GOOGLE" or "APPLE"
  oauthId        String?   @unique
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  primaryRegion  String?
  topSources     String[]
  topInterests   Json      @default("[]")
}