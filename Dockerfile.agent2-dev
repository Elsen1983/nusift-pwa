# ──────────────────────────────────────────────────────────────────────────────
# Dockerfile.agent2-dev
#
# Dev-only Linux runner for Agent 2 browser fallback parity.
#
# Mirrors the production Vercel runtime:
#   - Linux (Debian-based)
#   - playwright-core + @sparticuz/chromium (no full playwright)
#   - Node.js LTS
#
# NOT used in production. NOT deployed to Vercel.
# ──────────────────────────────────────────────────────────────────────────────

FROM node:22-bookworm-slim

# Install system dependencies required by @sparticuz/chromium
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    fonts-liberation \
    libasound2 \
    libatk-bridge2.0-0 \
    libatk1.0-0 \
    libcups2 \
    libdbus-1-3 \
    libdrm2 \
    libgbm1 \
    libgtk-3-0 \
    libnspr4 \
    libnss3 \
    libx11-xcb1 \
    libxcomposite1 \
    libxdamage1 \
    libxrandr2 \
    libxss1 \
    xdg-utils \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy dependency manifests first for deterministic installs
COPY package.json package-lock.json* ./
COPY prisma.config.ts ./
COPY prisma/ ./prisma/

# Install dependencies (production + dev, since this is a dev runner)
RUN npm install --ignore-scripts

# Generate Prisma client
RUN npx prisma generate

# Copy source files needed by the runner
COPY tsconfig.json ./
COPY scripts/dev/ ./scripts/dev/
COPY server/ ./server/

# Default environment: simulate Vercel runtime so the production
# browser code path (playwright-core + @sparticuz/chromium) is used
# instead of falling back to full playwright.
ENV NODE_ENV=development
ENV VERCEL=1
ENV NUXT_ENABLE_AGENT2_BROWSER_FALLBACK=true

ENTRYPOINT ["npx", "tsx"]
CMD ["scripts/dev/run-agent2-target.ts"]
